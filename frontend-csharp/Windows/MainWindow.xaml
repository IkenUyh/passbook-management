<Window x:Class="frontend_csharp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:frontend_csharp"
        xmlns:uc="clr-namespace:frontend_csharp.UserControls"
        mc:Ignorable="d"
        Height="720" Width="1080"
        WindowStyle="None"
        AllowsTransparency="True"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        ResizeMode="NoResize">

    <Window.Resources>
        <Style x:Key="CloseBtnStyle" TargetType="Button">
            <Setter Property="Background" Value="#FF4B2B" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="16"
                                BorderBrush="White"
                                BorderThickness="2">
                            <TextBlock Text="✕"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"
                                       FontWeight="Bold"
                                       FontSize="12"
                                       Margin="0,0,0,2" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="Transparent" Margin="15">
        <Border Background="White" CornerRadius="30">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="4*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" CornerRadius="30,0,0,30"
                        Background="#1F2937"></Border>

                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="2.25*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <Ellipse Width="200" Height="200" Stroke="White" StrokeThickness="2">
                            <Ellipse.Fill>
                                <ImageBrush ImageSource="{StaticResource User}" Stretch="UniformToFill"/>
                            </Ellipse.Fill>
                        </Ellipse>
                    </Grid>

                    <uc:SidePanel x:Name="MenuSidePanel" Grid.Row="1" Margin="0 20 0 20"></uc:SidePanel>

                </Grid>

                <Grid Grid.Column="1" Margin="25">
                    <ContentControl x:Name="MainContent" />
                </Grid>

            </Grid>
        </Border>

        <Button Style="{StaticResource CloseBtnStyle}"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,-10,-10,0"
                Click="CloseBtn_Click"
                Panel.ZIndex="100" />
    </Grid>
</Window>