<Window x:Class="frontend_csharp.Windows.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Authentication"
        Height="500"
        Width="700"
        WindowStyle="None"
        AllowsTransparency="True"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        ResizeMode="NoResize">

    <Window.Resources>
        <Style x:Key="InputContainer"
               TargetType="Border">
            <Setter Property="Background"
                    Value="White" />
            <Setter Property="BorderBrush"
                    Value="#DCDCDC" />
            <Setter Property="BorderThickness"
                    Value="1" />
            <Setter Property="CornerRadius"
                    Value="8" />
            <Setter Property="Height"
                    Value="42" />
            <Setter Property="Margin"
                    Value="0,10" />
            <Setter Property="Width"
                    Value="300" />
        </Style>

        <Style x:Key="SolidBtn"
               TargetType="Button">
            <Setter Property="Background"
                    Value="#1A1A1A" />
            <Setter Property="Foreground"
                    Value="White" />
            <Setter Property="Height"
                    Value="42" />
            <Setter Property="Width"
                    Value="300" />
            <Setter Property="FontWeight"
                    Value="Bold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="OutlineBtn"
               TargetType="Button">
            <Setter Property="Background"
                    Value="Transparent" />
            <Setter Property="Foreground"
                    Value="White" />
            <Setter Property="BorderBrush"
                    Value="White" />
            <Setter Property="BorderThickness"
                    Value="2" />
            <Setter Property="Height"
                    Value="42" />
            <Setter Property="Width"
                    Value="150" />
            <Setter Property="FontWeight"
                    Value="Bold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="21">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CloseBtnStyle"
               TargetType="Button">
            <Setter Property="Background"
                    Value="#FF4B2B" />
            <Setter Property="Foreground"
                    Value="White" />
            <Setter Property="Width"
                    Value="32" />
            <Setter Property="Height"
                    Value="32" />
            <Setter Property="Cursor"
                    Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="16"
                                BorderBrush="White"
                                BorderThickness="2">
                            <TextBlock Text="✕"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"
                                       FontWeight="Bold"
                                       FontSize="12"
                                       Margin="0,0,0,2" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="15">
        <Border Background="#F2F2F2"
                CornerRadius="30">
            <Grid>
                <Grid.OpacityMask>
                    <VisualBrush>
                        <VisualBrush.Visual>
                            <Border Background="Black"
                                    CornerRadius="30"
                                    Width="670"
                                    Height="470" />
                        </VisualBrush.Visual>
                    </VisualBrush>
                </Grid.OpacityMask>

                <Grid x:Name="SignInPanel"
                      Width="400"
                      HorizontalAlignment="Left"
                      Panel.ZIndex="1"
                      IsHitTestVisible="True">
                    <Grid.RenderTransform>
                        <TranslateTransform x:Name="SignInTransform"
                                            X="0" />
                    </Grid.RenderTransform>
                    <StackPanel VerticalAlignment="Center"
                                HorizontalAlignment="Center">
                        <TextBlock Text="Đăng nhập"
                                   FontSize="26"
                                   FontWeight="Bold"
                                   Foreground="#222"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,30" />

                        <Border Style="{StaticResource InputContainer}">
                            <Grid>
                                <TextBlock Text="email@domain.com"
                                           Foreground="Gray"
                                           VerticalAlignment="Center"
                                           Margin="18,0,0,0"
                                           IsHitTestVisible="False" />
                                <TextBox x:Name="txtUsernameSignIn"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         VerticalContentAlignment="Center"
                                         Padding="15,0"
                                         Foreground="#333"
                                         TextChanged="Placeholder_TextChanged" />
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource InputContainer}">
                            <Grid>
                                <TextBlock Text="Mật khẩu"
                                           Foreground="Gray"
                                           VerticalAlignment="Center"
                                           Margin="18,0,0,0"
                                           IsHitTestVisible="False" />
                                <PasswordBox x:Name="txtPasswordSignIn"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             VerticalContentAlignment="Center"
                                             Padding="15,0"
                                             Foreground="#333"
                                             PasswordChanged="Placeholder_PasswordChanged" />
                            </Grid>
                        </Border>

                        <Button Content="ĐĂNG NHẬP"
                                Style="{StaticResource SolidBtn}"
                                Margin="0,25,0,0"
                                Click="SignIn_Click" />
                    </StackPanel>
                </Grid>

                <Grid x:Name="SignUpPanel"
                      Width="400"
                      HorizontalAlignment="Left"
                      Panel.ZIndex="0"
                      Opacity="0"
                      IsHitTestVisible="False">
                    <Grid.RenderTransform>
                        <TranslateTransform x:Name="SignUpTransform"
                                            X="0" />
                    </Grid.RenderTransform>
                    <StackPanel VerticalAlignment="Center"
                                HorizontalAlignment="Center"
                                Width="300">
                        <TextBlock Text="Thông Tin Ứng Dụng"
                                   FontSize="26"
                                   FontWeight="Bold"
                                   Foreground="#222"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,20" />

                        <TextBlock Text="Hệ Thống Quản Lý"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="#333"
                                   HorizontalAlignment="Center"
                                   Margin="0,5" />

                        <TextBlock Text="Phiên bản: 1.0.0"
                                   FontSize="14"
                                   Foreground="Gray"
                                   HorizontalAlignment="Center"
                                   Margin="0,5" />

                        <TextBlock Text="Phát triển bởi: Nhóm 13"
                                   FontSize="14"
                                   Foreground="Gray"
                                   HorizontalAlignment="Center"
                                   Margin="0,5" />

                        <TextBlock Text="Ứng dụng hỗ trợ tối ưu hóa quy trình vận hành, quản lý dữ liệu mượt mà và bảo mật."
                                   Foreground="#666"
                                   FontSize="13"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   Margin="0,15,0,0"
                                   LineHeight="18" />

                        <Button Width="75" Height="50" 
                                Background="Transparent" 
                                BorderThickness="0" 
                                Cursor="Hand" 
                                Margin="0,25,0,0"
                                Click="GithubBtn_Click"
                                ToolTip="Xem mã nguồn trên GitHub">
                            <materialDesign:PackIcon Kind="Github" Width="50" Height="50" Foreground="#333333"
                                                     VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Button>
                    </StackPanel>
                </Grid>

                <Border x:Name="OverlayPanel"
                        Width="250"
                        HorizontalAlignment="Left"
                        Panel.ZIndex="10"
                        Margin="10"
                        CornerRadius="25">
                    <Border.RenderTransform>
                        <TranslateTransform x:Name="OverlayTransform"
                                            X="400" />
                    </Border.RenderTransform>
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0"
                                             EndPoint="1,1">
                            <GradientStop x:Name="Stop1"
                                          Color="#FF0080"
                                          Offset="0.0" />
                            <GradientStop x:Name="Stop2"
                                          Color="#FF8C00"
                                          Offset="1.0" />
                        </LinearGradientBrush>
                    </Border.Background>

                    <Grid>
                        <StackPanel x:Name="OverlaySignUpContent"
                                    VerticalAlignment="Center"
                                    Margin="20">
                            <TextBlock Text="Khám phá!"
                                       FontSize="26"
                                       FontWeight="Bold"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,12" />
                            <TextBlock Text="Xem thông tin chi tiết và phiên bản phát triển của ứng dụng"
                                       Foreground="White"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,30"
                                       FontSize="13"
                                       LineHeight="18" />
                            <Button Content="XEM THÔNG TIN"
                                    Style="{StaticResource OutlineBtn}"
                                    Click="ShowSignUp_Click" />
                        </StackPanel>

                        <StackPanel x:Name="OverlaySignInContent"
                                    VerticalAlignment="Center"
                                    Margin="20"
                                    Opacity="0"
                                    IsHitTestVisible="False">
                            <TextBlock Text="Đăng nhập"
                                       FontSize="26"
                                       FontWeight="Bold"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,12" />
                            <TextBlock Text="Quay lại màn hình đăng nhập hệ thống"
                                       Foreground="White"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,30"
                                       FontSize="13"
                                       LineHeight="18" />
                            <Button Content="ĐĂNG NHẬP"
                                    Style="{StaticResource OutlineBtn}"
                                    Click="ShowSignIn_Click" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <Button Style="{StaticResource CloseBtnStyle}"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,-10,-10,0"
                Click="CloseBtn_Click"
                Panel.ZIndex="100" />
    </Grid>
</Window>