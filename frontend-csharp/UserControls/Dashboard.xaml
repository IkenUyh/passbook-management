<UserControl x:Class="frontend_csharp.UserControls.Dashboard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:frontend_csharp.UserControls"
             xmlns:vm="clr-namespace:frontend_csharp.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="720" d:DesignWidth="850"
             Background="White">

    <UserControl.DataContext>
        <vm:DashboardViewModel />
    </UserControl.DataContext>

    <UserControl.Resources>
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="18"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="10" x:Name="MainContent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Tổng thu trong ngày" FontSize="13" Foreground="#666" FontFamily="Segoe UI"/>
                    <TextBlock Grid.Row="1" Text="{Binding TongThuString}" FontSize="24" FontWeight="Bold" FontFamily="Segoe UI" VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Tổng chi trong ngày" FontSize="13" Foreground="#666" FontFamily="Segoe UI"/>
                    <TextBlock Grid.Row="1" Text="{Binding TongChiString}" FontSize="24" FontWeight="Bold" FontFamily="Segoe UI" VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <Border Grid.Column="4" Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Số lượng sổ đang mở" FontSize="13" Foreground="#666" FontFamily="Segoe UI"/>
                    <TextBlock Grid.Row="1" Text="{Binding SoLuongSoString}" FontSize="36" FontWeight="Bold" FontFamily="Segoe UI" VerticalAlignment="Center"/>
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.Row="1" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.6*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardStyle}" Padding="18,18,18,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Biến động số dư" FontSize="14" FontWeight="SemiBold" FontFamily="Segoe UI" Margin="0,0,0,0" Panel.ZIndex="1"/>

                    <Grid Grid.Row="1">
                        <lvc:CartesianChart MinHeight="180" Margin="0,-10,0,-5"
                                Background="Transparent"
                                Series="{Binding LineSeries}" 
                                XAxes="{Binding LineXAxes}" 
                                YAxes="{Binding LineYAxes}">
                            <lvc:CartesianChart.Style>
                                <Style TargetType="lvc:CartesianChart">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsLineDataEmpty}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </lvc:CartesianChart.Style>
                        </lvc:CartesianChart>

                        <TextBlock
                            Text="Không có dữ liệu" 
                            Foreground="#999" 
                            FontSize="13"
                            FontWeight="Bold"
                            FontFamily="Segoe UI" 
                            HorizontalAlignment="Center" 
                            VerticalAlignment="Center"
                            Margin="0,0,0,20">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsLineDataEmpty}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Sổ sắp đến hạn" FontSize="14" FontWeight="SemiBold" FontFamily="Segoe UI" Margin="0,0,0,10"/>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden">
                        <Grid>
                            <ItemsControl x:Name="SoSapDenHanCtrl" ItemsSource="{Binding SoSapDenHanList}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="0,0,0,14">
                                            <TextBlock FontSize="13" FontFamily="Segoe UI">
                            <Run FontWeight="SemiBold" Text="{Binding Id}"/>
                            <Run Text=" - "/>
                            <Run Text="{Binding TenKhachHang}"/>
                                            </TextBlock>
                                            <TextBlock Text="{Binding NgayDaoHanText}" FontSize="12" Foreground="#888"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <TextBlock
                                Text="Không có dữ liệu" 
                                Foreground="#999" 
                                FontSize="13"
                                FontWeight="Bold"
                                FontFamily="Segoe UI" 
                                HorizontalAlignment="Center" 
                                VerticalAlignment="Center" 
                                Margin="0,0,0,40">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasItems, ElementName=SoSapDenHanCtrl}" Value="False">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="1.3*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Sổ tiết kiệm mới nhất" FontSize="14" FontWeight="SemiBold" FontFamily="Segoe UI" Margin="0,0,0,10"/>

                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Hidden">
                        <Grid>
                            <ItemsControl x:Name="SoMoiNhatCtrl" ItemsSource="{Binding SoMoiNhatList}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel>
                                            <Grid Margin="0,4">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="70"/>
                                                    <ColumnDefinition Width="100"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding TenKhachHang}" FontSize="12"/>
                                                <TextBlock Grid.Column="1" Text="{Binding Id}" FontSize="12" TextAlignment="Center"/>
                                                <TextBlock Grid.Column="2" Text="{Binding SoDuText}" FontSize="12" TextAlignment="Right"/>
                                            </Grid>
                                            <Border Height="1" Background="#F0F0F0"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <TextBlock
                                Text="Không có dữ liệu" 
                                Foreground="#999" 
                                FontSize="12"
                                FontWeight="Bold"
                                FontFamily="Segoe UI" 
                                HorizontalAlignment="Center" 
                                VerticalAlignment="Center" 
                                Margin="0,0,0,20">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasItems, ElementName=SoMoiNhatCtrl}" Value="False">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </ScrollViewer>
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource CardStyle}" Padding="18,18,18,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Biểu đồ Mở/Đóng sổ theo tháng" FontSize="14" FontWeight="SemiBold" FontFamily="Segoe UI" Margin="0,0,0,0" Panel.ZIndex="1"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,2,5,0" Panel.ZIndex="1">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsBarDataEmpty}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <Ellipse Width="7" Height="7" Fill="#2DB87F" Margin="0,0,4,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Mở sổ" FontSize="10" Foreground="#666" Margin="0,0,12,0"/>
                        <Ellipse Width="7" Height="7" Fill="#2D3436" Margin="0,0,4,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Đóng sổ" FontSize="10" Foreground="#666"/>
                    </StackPanel>

                    <TextBlock Text="2026" Grid.Row="1" FontSize="10" FontWeight="SemiBold" Foreground="#999" 
                   HorizontalAlignment="Left" VerticalAlignment="Bottom" 
                   Margin="5,0,0,10" Panel.ZIndex="1">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsBarDataEmpty}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <Grid Grid.Row="1">
                        <lvc:CartesianChart LegendPosition="Hidden"
                                TooltipPosition="Right"
                                Margin="0,-10,0,10"
                                Background="Transparent"
                                Series="{Binding BarSeries}" 
                                XAxes="{Binding BarXAxes}" 
                                YAxes="{Binding BarYAxes}">
                            <lvc:CartesianChart.Style>
                                <Style TargetType="lvc:CartesianChart">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsBarDataEmpty}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </lvc:CartesianChart.Style>
                        </lvc:CartesianChart>

                        <TextBlock
                            Text="Không có dữ liệu" 
                            Foreground="#999" 
                            FontSize="13"
                            FontWeight="Bold"
                            FontFamily="Segoe UI" 
                            HorizontalAlignment="Center" 
                            VerticalAlignment="Center"
                            Margin="0,0,0,10">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsBarDataEmpty}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>