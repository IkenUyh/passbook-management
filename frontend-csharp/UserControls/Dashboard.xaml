<UserControl x:Class="frontend_csharp.UserControls.Dashboard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:frontend_csharp.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="720" d:DesignWidth="850"
             Background="White">

    <UserControl.DataContext>
        <local:DashboardViewModel />
    </UserControl.DataContext>

    <UserControl.Resources>
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="18"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Hệ Thống Quản Lý Sổ Tiết Kiệm"
                       FontSize="18" FontWeight="Bold" FontFamily="Segoe UI"
                       VerticalAlignment="Center"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button Cursor="Hand" Padding="14,8" Margin="0,0,10,0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="#2DB87F" CornerRadius="8" Padding="14,8">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📥" FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock Text="Tải Dashboard" Foreground="White" FontSize="13"
                                               FontWeight="SemiBold" FontFamily="Segoe UI" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Ellipse Width="36" Height="36">
                    <Ellipse.Fill>
                        <ImageBrush ImageSource="/Assets/user_active.jpg" Stretch="UniformToFill"/>
                    </Ellipse.Fill>
                </Ellipse>
                <TextBlock Text="▾" FontSize="14" VerticalAlignment="Center" Margin="4,0,0,0" Foreground="#888"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Tổng thu trong ngày" FontSize="13" Foreground="#666" FontFamily="Segoe UI"/>
                    <TextBlock Grid.Row="1" Text="45.678.000 VNĐ" FontSize="24" FontWeight="Bold" FontFamily="Segoe UI" VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Tổng chi trong ngày" FontSize="13" Foreground="#666" FontFamily="Segoe UI"/>
                    <TextBlock Grid.Row="1" Text="15.500.000 VNĐ" FontSize="24" FontWeight="Bold" FontFamily="Segoe UI" VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <Border Grid.Column="4" Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Số lượng sổ đang mở" FontSize="13" Foreground="#666" FontFamily="Segoe UI"/>
                    <TextBlock Grid.Row="1" Text="50" FontSize="36" FontWeight="Bold" FontFamily="Segoe UI" VerticalAlignment="Center"/>
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.Row="2" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.6*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardStyle}" Padding="18,18,18,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Biến động số dư" FontSize="14" FontWeight="SemiBold" FontFamily="Segoe UI" Margin="0,0,0,0" Panel.ZIndex="1"/>

                    <lvc:CartesianChart Grid.Row="1" 
                                        MinHeight="180"
                                        Margin="0,-10,0,-5"
                                        Background="Transparent"
                                        Series="{Binding LineSeries}" 
                                        XAxes="{Binding LineXAxes}" 
                                        YAxes="{Binding LineYAxes}"/>
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Sổ sắp đến hạn" FontSize="14" FontWeight="SemiBold" FontFamily="Segoe UI" Margin="0,0,0,10"/>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden">
                        <StackPanel>
                            <StackPanel Margin="0,0,0,14">
                                <TextBlock FontSize="13" FontFamily="Segoe UI"><Run FontWeight="SemiBold" Text="STK001"/><Run Text=" - Nguyễn Văn A"/></TextBlock>
                                <TextBlock Text="Đáo hạn: 15/04/2026" FontSize="12" Foreground="#888"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,0,14">
                                <TextBlock FontSize="13" FontFamily="Segoe UI"><Run FontWeight="SemiBold" Text="STK001"/><Run Text=" - Nguyễn Văn A"/></TextBlock>
                                <TextBlock Text="Đáo hạn: 15/04/2026" FontSize="12" Foreground="#888"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,0,14">
                                <TextBlock FontSize="13" FontFamily="Segoe UI"><Run FontWeight="SemiBold" Text="STK001"/><Run Text=" - Nguyễn Văn A"/></TextBlock>
                                <TextBlock Text="Đáo hạn: 15/04/2026" FontSize="12" Foreground="#888"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,0,14">
                                <TextBlock FontSize="13" FontFamily="Segoe UI"><Run FontWeight="SemiBold" Text="STK001"/><Run Text=" - Nguyễn Văn A"/></TextBlock>
                                <TextBlock Text="Đáo hạn: 15/04/2026" FontSize="12" Foreground="#888"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,0,0">
                                <TextBlock FontSize="13" FontFamily="Segoe UI"><Run FontWeight="SemiBold" Text="STK001"/><Run Text=" - Nguyễn Văn A"/></TextBlock>
                                <TextBlock Text="Đáo hạn: 15/04/2026" FontSize="12" Foreground="#888"/>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="1.3*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Sổ tiết kiệm mới nhất" FontSize="14" FontWeight="SemiBold" FontFamily="Segoe UI" Margin="0,0,0,10"/>

                    <Grid Grid.Row="1" Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="100"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Khách hàng" FontSize="12" FontWeight="SemiBold" Foreground="#666"/>
                        <TextBlock Grid.Column="1" Text="Mã số" FontSize="12" FontWeight="SemiBold" Foreground="#666" TextAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="Số dư" FontSize="12" FontWeight="SemiBold" Foreground="#666" TextAlignment="Right"/>
                    </Grid>

                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Hidden">
                        <StackPanel>
                            <Grid Margin="0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="100"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Nguyễn Văn A" FontSize="12"/>
                                <TextBlock Grid.Column="1" Text="4321" FontSize="12" TextAlignment="Center"/>
                                <TextBlock Grid.Column="2" Text="50.000.000đ" FontSize="12" TextAlignment="Right"/>
                            </Grid>
                            <Border Height="1" Background="#F0F0F0"/>

                            <Grid Margin="0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="100"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Nguyễn Văn A" FontSize="12"/>
                                <TextBlock Grid.Column="1" Text="4033" FontSize="12" TextAlignment="Center"/>
                                <TextBlock Grid.Column="2" Text="50.000.000đ" FontSize="12" TextAlignment="Right"/>
                            </Grid>
                            <Border Height="1" Background="#F0F0F0"/>

                            <Grid Margin="0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="100"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Nguyễn Văn A" FontSize="12"/>
                                <TextBlock Grid.Column="1" Text="3128" FontSize="12" TextAlignment="Center"/>
                                <TextBlock Grid.Column="2" Text="50.000.000đ" FontSize="12" TextAlignment="Right"/>
                            </Grid>
                            <Border Height="1" Background="#F0F0F0"/>

                            <Grid Margin="0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="100"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Nguyễn Văn A" FontSize="12"/>
                                <TextBlock Grid.Column="1" Text="2104" FontSize="12" TextAlignment="Center"/>
                                <TextBlock Grid.Column="2" Text="50.000.000đ" FontSize="12" TextAlignment="Right"/>
                            </Grid>
                            <Border Height="1" Background="#F0F0F0"/>

                            <Grid Margin="0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="100"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Nguyễn Văn A" FontSize="12"/>
                                <TextBlock Grid.Column="1" Text="2003" FontSize="12" TextAlignment="Center"/>
                                <TextBlock Grid.Column="2" Text="50.000.000đ" FontSize="12" TextAlignment="Right"/>
                            </Grid>
                            <Border Height="1" Background="#F0F0F0"/>

                            <Grid Margin="0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="100"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Nguyễn Văn A" FontSize="12"/>
                                <TextBlock Grid.Column="1" Text="1894" FontSize="12" TextAlignment="Center"/>
                                <TextBlock Grid.Column="2" Text="50.000.000đ" FontSize="12" TextAlignment="Right"/>
                            </Grid>
                            <Border Height="1" Background="#F0F0F0"/>

                            <Grid Margin="0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="100"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Nguyễn Văn A" FontSize="12"/>
                                <TextBlock Grid.Column="1" Text="405" FontSize="12" TextAlignment="Center"/>
                                <TextBlock Grid.Column="2" Text="50.000.000đ" FontSize="12" TextAlignment="Right"/>
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource CardStyle}" Padding="18,18,18,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Biểu đồ Mở/Đóng sổ theo tháng" FontSize="14" FontWeight="SemiBold" FontFamily="Segoe UI" Margin="0,0,0,0" Panel.ZIndex="1"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,2,5,0" Panel.ZIndex="1">
                        <Ellipse Width="7" Height="7" Fill="#2DB87F" Margin="0,0,4,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Mở sổ" FontSize="10" Foreground="#666" Margin="0,0,12,0"/>
                        <Ellipse Width="7" Height="7" Fill="#2D3436" Margin="0,0,4,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Đóng sổ" FontSize="10" Foreground="#666"/>
                    </StackPanel>

                    <TextBlock Text="2026" Grid.Row="1" FontSize="10" FontWeight="SemiBold" Foreground="#999" 
                               HorizontalAlignment="Left" VerticalAlignment="Bottom" 
                               Margin="5,0,0,10" Panel.ZIndex="1"/>

                    <lvc:CartesianChart Grid.Row="1"
                                        LegendPosition="Hidden"
                                        TooltipPosition="Right"
                                        Margin="0,-10,0,10"
                                        Background="Transparent"
                                        Series="{Binding BarSeries}" 
                                        XAxes="{Binding BarXAxes}" 
                                        YAxes="{Binding BarYAxes}"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>