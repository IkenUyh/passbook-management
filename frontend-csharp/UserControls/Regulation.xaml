<UserControl x:Class="frontend_csharp.UserControls.Regulation"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:frontend_csharp.UserControls"
             xmlns:vm="clr-namespace:frontend_csharp.ViewModels"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d" 
             d:DesignHeight="720" d:DesignWidth="850"
             Background="White"
             Loaded="UserControl_Loaded">

    <UserControl.DataContext>
        <vm:RegulationViewModel />
    </UserControl.DataContext>

    <UserControl.Resources>
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="24"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>

        <Style x:Key="InputTextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="40"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#6B7280"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                Background="White" CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GreenButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#10B981"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#059669"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="GrayButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#F3F4F6"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E5E7EB"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Border x:Key="AddTermPopupUI" Width="450" Background="White" CornerRadius="12" Padding="30" VerticalAlignment="Center" HorizontalAlignment="Center">
            <StackPanel>
                <TextBlock Text="Thêm kỳ hạn mới" FontSize="20" FontWeight="Bold" Foreground="#111827" Margin="0,0,0,20"/>

                <StackPanel Margin="0,0,0,16">
                    <TextBlock Text="Kỳ hạn (Tháng)" FontSize="13" FontWeight="SemiBold" Foreground="#4B5563" Margin="0,0,0,8"/>
                    <TextBox Style="{StaticResource InputTextBoxStyle}" x:Name="txtKyHan" Padding="12,0"/>
                </StackPanel>

                <StackPanel Margin="0,0,0,16">
                    <TextBlock Text="Lãi suất (%/năm)" FontSize="13" FontWeight="SemiBold" Foreground="#4B5563" Margin="0,0,0,8"/>
                    <TextBox Style="{StaticResource InputTextBoxStyle}" x:Name="txtLaiSuat" Padding="12,0"/>
                </StackPanel>

                <StackPanel Margin="0,0,0,24">
                    <TextBlock Text="Ghi chú" FontSize="13" FontWeight="SemiBold" Foreground="#4B5563" Margin="0,0,0,8"/>
                    <TextBox Style="{StaticResource InputTextBoxStyle}" x:Name="txtGhiChu" Padding="12,0"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Style="{StaticResource GrayButtonStyle}" Content="Hủy" Click="CloseAddTermPopup_Click" Width="100" Margin="0,0,10,0"/>
                    <Button Style="{StaticResource GreenButtonStyle}" Content="Thêm" Click="SaveAddTermPopup_Click" Width="100"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <Border x:Key="EditTermPopupUI" Width="450" Background="White" CornerRadius="12" Padding="30" VerticalAlignment="Center" HorizontalAlignment="Center">
            <StackPanel>
                <TextBlock Text="Chỉnh sửa kỳ hạn" FontSize="20" FontWeight="Bold" Foreground="#111827" Margin="0,0,0,20"/>

                <StackPanel Margin="0,0,0,16">
                    <TextBlock Text="Kỳ hạn (Tháng)" FontSize="13" FontWeight="SemiBold" Foreground="#4B5563" Margin="0,0,0,8"/>
                    <TextBox Style="{StaticResource InputTextBoxStyle}" Text="{Binding KyHanDangSua.TenKyHan, UpdateSourceTrigger=PropertyChanged}" Padding="12,0"/>
                </StackPanel>

                <StackPanel Margin="0,0,0,16">
                    <TextBlock Text="Lãi suất (%/năm)" FontSize="13" FontWeight="SemiBold" Foreground="#4B5563" Margin="0,0,0,8"/>
                    <TextBox Style="{StaticResource InputTextBoxStyle}" Text="{Binding KyHanDangSua.LaiSuat, UpdateSourceTrigger=PropertyChanged}" Padding="12,0"/>
                </StackPanel>

                <StackPanel Margin="0,0,0,24">
                    <TextBlock Text="Ghi chú" FontSize="13" FontWeight="SemiBold" Foreground="#4B5563" Margin="0,0,0,8"/>
                    <TextBox Style="{StaticResource InputTextBoxStyle}" Text="{Binding KyHanDangSua.GhiChu, UpdateSourceTrigger=PropertyChanged}" Padding="12,0"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Style="{StaticResource GrayButtonStyle}" Content="Hủy" Click="CloseEditTermPopup_Click" Width="100" Margin="0,0,10,0"/>
                    <Button Style="{StaticResource GreenButtonStyle}" Content="Cập nhật" Click="SaveEditTermPopup_Click" Width="100"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </UserControl.Resources>

    <Grid Margin="10" x:Name="MainContent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="15"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource CardStyle}" Margin="0">
            <StackPanel>
                <TextBlock Text="Quy định chung" FontSize="26" FontWeight="Bold" FontFamily="Segoe UI" Margin="0,0,0,24" Foreground="#111827"/>

                <Grid Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock 
                            Text="Số tiền gửi tối thiểu ban đầu (VNĐ)"
                            TextWrapping="Wrap"
                            FontSize="12" 
                            FontWeight="SemiBold" 
                            Foreground="#111827" 
                            Margin="0,0,0,8"/>
                        <TextBox 
                            Style="{StaticResource InputTextBoxStyle}" 
                            Text="{Binding RegulationInfo.TienGuiToiThieu, StringFormat={}{0:N0}}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock 
                            Text="Số tiền gửi thêm tối thiểu (VNĐ)"
                            TextWrapping="Wrap"
                            FontSize="12" 
                            FontWeight="SemiBold" 
                            Foreground="#111827" 
                            Margin="0,0,0,8"/>
                        <TextBox 
                            Style="{StaticResource InputTextBoxStyle}" 
                            Text="{Binding RegulationInfo.TienGuiThemToiThieu, StringFormat={}{0:N0}}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="4">
                        <Viewbox 
                            StretchDirection="DownOnly" 
                            HorizontalAlignment="Left" 
                            Margin="0,0,0,8">
                            <TextBlock 
                                Text="Thời gian gửi tối thiểu để được rút (Ngày)" 
                                FontSize="12" 
                                FontWeight="SemiBold" 
                                Foreground="#111827"/>
                        </Viewbox>
                        <TextBox 
                            Style="{StaticResource InputTextBoxStyle}" 
                            Text="{Binding RegulationInfo.ThoiGianGuiToiThieuNgay}"/>
                    </StackPanel>
                </Grid>

                <Button Style="{StaticResource GreenButtonStyle}" HorizontalAlignment="Right" Click="BtnLuuThayDoiThamSo_Click">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="ContentSaveOutline" Width="18" Height="18" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Lưu thay đổi" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource CardStyle}" Margin="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,24">
                    <TextBlock Text="Cấu hình Kỳ hạn &amp; Lãi suất" FontSize="26" FontWeight="Bold" FontFamily="Segoe UI" VerticalAlignment="Center" Foreground="#111827"/>
                    <Button Style="{StaticResource GreenButtonStyle}" Click="OpenAddTermPopup_Click" HorizontalAlignment="Right" Padding="12,8">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Plus" Width="18" Height="18" Margin="0,0,4,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Thêm kỳ hạn" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>

                <DataGrid Grid.Row="1" 
                          ItemsSource="{Binding DanhSachKyHan}" 
                          AutoGenerateColumns="False" 
                          CanUserAddRows="False" 
                          HeadersVisibility="Column" 
                          GridLinesVisibility="None" 
                          BorderThickness="0" 
                          Background="White" 
                          RowBackground="White"
                          VerticalScrollBarVisibility="Auto" 
                          HorizontalScrollBarVisibility="Disabled" 
                          IsReadOnly="True"
                          SelectionMode="Single">

                    <DataGrid.Resources>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="White"/>
                            <Setter Property="Foreground" Value="#111827"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="FontSize" Value="12"/>
                            <Setter Property="Padding" Value="0,0,0,16"/>
                            <Setter Property="BorderThickness" Value="0"/>
                        </Style>

                        <Style TargetType="DataGridCell">
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Padding" Value="0,12"/>
                            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="DataGridCell">
                                        <Border Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}">
                                            <ContentPresenter VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="Black"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>

                        <Style TargetType="DataGridRow">
                            <Setter Property="Background" Value="White"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="White"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="White"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.Resources>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="STT" Binding="{Binding STT}" Width="60">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#9CA3AF"/>
                                    <Setter Property="FontSize" Value="13"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Kỳ hạn (Tháng)" Binding="{Binding TenKyHan}" Width="1.5*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#111827"/>
                                    <Setter Property="FontWeight" Value="Medium"/>
                                    <Setter Property="FontSize" Value="13"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Lãi suất (%/năm)" Binding="{Binding LaiSuat}" Width="1.5*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#111827"/>
                                    <Setter Property="FontWeight" Value="Medium"/>
                                    <Setter Property="FontSize" Value="13"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Ghi chú" Binding="{Binding GhiChu}" Width="2*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#111827"/>
                                    <Setter Property="FontWeight" Value="Medium"/>
                                    <Setter Property="FontSize" Value="13"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTemplateColumn Header="Thao tác" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Background="Transparent" BorderThickness="0" Padding="0" Margin="0,0,12,0" Cursor="Hand" Foreground="#111827"
                                                Click="OpenEditTermPopup_Click">
                                            <materialDesign:PackIcon Kind="Pencil" Width="18" Height="18"/>
                                        </Button>
                                        <Button Background="Transparent" BorderThickness="0" Padding="0" Cursor="Hand" Foreground="#111827">
                                            <materialDesign:PackIcon Kind="TrashCanOutline" Width="18" Height="18"/>
                                        </Button>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>