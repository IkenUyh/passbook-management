<UserControl x:Class="frontend_csharp.UserControls.ReportsManagement"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             xmlns:vm="clr-namespace:frontend_csharp.ViewModels"
             mc:Ignorable="d" 
             Background="White"
             d:DesignHeight="700" d:DesignWidth="790">

    <UserControl.Resources>
        <vm:ReportsManagementViewModel x:Key="ChartViewModel" />

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#6B7280"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="10,15,10,15"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#F3F4F6"/>
                    <Setter Property="Foreground" Value="Black"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="1.2*"/>
        </Grid.RowDefinitions>

        <!-- Doanh số ngày -->
        <Grid Grid.Row="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Doanh số hoạt động ngày" FontSize="16" FontWeight="Bold" Foreground="#374151" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <TextBlock Text="Ngày:" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="#374151"/>
                    <DatePicker x:Name="dpDailyDate" Width="150" VerticalAlignment="Center" FontSize="13" SelectedDateChanged="dpDailyDate_SelectedDateChanged"/>
                </StackPanel>
            </Grid>

            <DataGrid x:Name="dgvDailyReport" Grid.Row="1" AutoGenerateColumns="False" CanUserAddRows="False" SelectionMode="Single" 
                      HeadersVisibility="Column" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#F3F4F6" 
                      BorderThickness="0" Background="White" RowBackground="White"
                      ScrollViewer.VerticalScrollBarVisibility="Auto" ScrollViewer.HorizontalScrollBarVisibility="Hidden"
                      CanUserResizeColumns="False" CanUserReorderColumns="False" CanUserSortColumns="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="STT" Binding="{Binding Stt}" Width="60" Foreground="#9CA3AF" IsReadOnly="True" FontSize="13"/>
                    <DataGridTextColumn Header="Loại tiết kiệm" Binding="{Binding SavingsType}" FontWeight="SemiBold" Width="1*" IsReadOnly="True" FontSize="13"/>
                    <DataGridTextColumn Header="Tổng thu" Binding="{Binding TotalIn, StringFormat={}{0:N0} VNĐ}" Width="1*" IsReadOnly="True" FontSize="13"/>
                    <DataGridTextColumn Header="Tổng chi" Binding="{Binding TotalOut, StringFormat={}{0:N0} VNĐ}" Width="1*" IsReadOnly="True" FontSize="13"/>
                    <DataGridTextColumn Header="Chênh lệch" Binding="{Binding Difference, StringFormat={}{0:N0} VNĐ}" FontWeight="Bold" Width="1*" IsReadOnly="True" FontSize="13">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsPositive}" Value="True">
                                        <Setter Property="Foreground" Value="#10B981"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsPositive}" Value="False">
                                        <Setter Property="Foreground" Value="#EF4444"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <!-- Mở / Đóng sổ tháng -->
        <Grid Grid.Row="2" DataContext="{StaticResource ChartViewModel}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Mở / Đóng sổ tháng" FontSize="16" FontWeight="Bold" Foreground="#374151" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <TextBlock Text="Loại:" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="#374151"/>

                    <ComboBox Width="120" Margin="0,0,15,0" VerticalAlignment="Center" FontSize="13" 
                              ItemsSource="{Binding SavingsTypes}" 
                              SelectedItem="{Binding SelectedSavingsType, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Text="Tháng:" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="#374151"/>

                    <DatePicker Width="120" VerticalAlignment="Center" FontSize="13" 
                                SelectedDate="{Binding SelectedMonthlyDate, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Top" Panel.ZIndex="1">
                    <Ellipse Width="10" Height="10" Fill="#10B981" Margin="0,0,6,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Mở sổ" FontSize="11" Foreground="#374151" Margin="0,0,16,0" VerticalAlignment="Center"/>
                    <Ellipse Width="10" Height="10" Fill="#1F2937" Margin="0,0,6,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Đóng sổ" FontSize="11" Foreground="#374151" VerticalAlignment="Center"/>
                </StackPanel>

                <lvc:CartesianChart Margin="0,20,0,0"
                                    LegendPosition="Hidden"
                                    TooltipPosition="Top"
                                    Series="{Binding BarSeries}" 
                                    XAxes="{Binding BarXAxes}" 
                                    YAxes="{Binding BarYAxes}"/>
            </Grid>
        </Grid>

    </Grid>
</UserControl>