<Window x:Class="frontend_csharp.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:frontend_csharp.Views"
        mc:Ignorable="d"
        Title="Sign In" Height="600" Width="500" Background="White">
    <Grid VerticalAlignment="Center" HorizontalAlignment="Center" Width="350">
        <StackPanel>

            <TextBlock Text="App Name" 
                       FontSize="28" 
                       FontWeight="Bold" 
                       HorizontalAlignment="Center" 
                       Margin="0,0,0,40"/>

            <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="6" Height="40">
                <TextBox Text="email@domain.com" 
                         BorderThickness="0" 
                         VerticalContentAlignment="Center" 
                         Padding="10,0" 
                         Foreground="Gray"/>
            </Border>

            <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="6" Height="40">
                <PasswordBox Password="password" 
                             BorderThickness="0" 
                             VerticalContentAlignment="Center" 
                             Padding="10,0" 
                             Foreground="Gray"/>
            </Border>

            <Button Content="Sign in" 
                    Background="Black" 
                    Foreground="White" 
                    Height="40" 
                    FontSize="14" 
                    FontWeight="SemiBold" Click="SignIn_Click">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="6"/>
                    </Style>
                </Button.Resources>
            </Button>

            <Grid Margin="0,10">
                <Separator VerticalAlignment="Center" Background="#F0F0F0"/>
                <TextBlock Text="or continue with" 
                           Background="White" 
                           HorizontalAlignment="Center" 
                           Padding="10,0" 
                           Foreground="Gray" 
                           FontSize="12"/>
            </Grid>

            <Button Background="#F0F0F0" 
                    BorderThickness="0" 
                    Height="40">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="6"/>
                    </Style>
                </Button.Resources>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="G" Foreground="#4285F4" FontWeight="Bold" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Google" Foreground="Black" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <TextBlock TextWrapping="Wrap" 
                       TextAlignment="Center" 
                       Foreground="Gray" 
                       FontSize="11" 
                       Margin="0,20,0,0">
                By clicking continue, you agree to our <Run FontWeight="SemiBold" Foreground="Black">Terms of Service</Run> and <Run FontWeight="SemiBold" Foreground="Black">Privacy Policy</Run>
            </TextBlock>

        </StackPanel>
    </Grid>
</Window>
