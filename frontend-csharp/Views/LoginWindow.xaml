<Window x:Class="frontend_csharp.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Authentication"
        Height="500"
        Width="700"
        WindowStyle="None"
        AllowsTransparency="True"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        ResizeMode="NoResize">

    <Window.Resources>
        <Style x:Key="InputContainer"
               TargetType="Border">
            <Setter Property="Background"
                    Value="White" />
            <Setter Property="BorderBrush"
                    Value="#DCDCDC" />
            <Setter Property="BorderThickness"
                    Value="1" />
            <Setter Property="CornerRadius"
                    Value="8" />
            <Setter Property="Height"
                    Value="42" />
            <Setter Property="Margin"
                    Value="0,8" />
            <Setter Property="Width"
                    Value="300" />
        </Style>

        <Style x:Key="LinkBtn"
               TargetType="Button">
            <Setter Property="Background"
                    Value="Transparent" />
            <Setter Property="Foreground"
                    Value="Gray" />
            <Setter Property="FontSize"
                    Value="12" />
            <Setter Property="Cursor"
                    Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <TextBlock Text="{TemplateBinding Content}"
                                   TextDecorations="None">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver"
                                                 Value="True">
                                            <Setter Property="Foreground"
                                                    Value="#FF4B2B" />
                                            <Setter Property="TextDecorations"
                                                    Value="Underline" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SolidBtn"
               TargetType="Button">
            <Setter Property="Background"
                    Value="#1A1A1A" />
            <Setter Property="Foreground"
                    Value="White" />
            <Setter Property="Height"
                    Value="42" />
            <Setter Property="Width"
                    Value="300" />
            <Setter Property="FontWeight"
                    Value="Bold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="OutlineBtn"
               TargetType="Button">
            <Setter Property="Background"
                    Value="Transparent" />
            <Setter Property="Foreground"
                    Value="White" />
            <Setter Property="BorderBrush"
                    Value="White" />
            <Setter Property="BorderThickness"
                    Value="2" />
            <Setter Property="Height"
                    Value="42" />
            <Setter Property="Width"
                    Value="140" />
            <Setter Property="FontWeight"
                    Value="Bold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="21">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CloseBtnStyle"
               TargetType="Button">
            <Setter Property="Background"
                    Value="#FF4B2B" />
            <Setter Property="Foreground"
                    Value="White" />
            <Setter Property="Width"
                    Value="32" />
            <Setter Property="Height"
                    Value="32" />
            <Setter Property="Cursor"
                    Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="16"
                                BorderBrush="White"
                                BorderThickness="2">
                            <TextBlock Text="✕"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"
                                       FontWeight="Bold"
                                       FontSize="12"
                                       Margin="0,0,0,2" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="15">
        <Border Background="#F2F2F2"
                CornerRadius="30">
            <Grid>
                <Grid.OpacityMask>
                    <VisualBrush>
                        <VisualBrush.Visual>
                            <Border Background="Black"
                                    CornerRadius="30"
                                    Width="670"
                                    Height="470" />
                        </VisualBrush.Visual>
                    </VisualBrush>
                </Grid.OpacityMask>

                <Grid x:Name="SignInPanel"
                      Width="400"
                      HorizontalAlignment="Left"
                      Panel.ZIndex="1"
                      IsHitTestVisible="True">
                    <Grid.RenderTransform>
                        <TranslateTransform x:Name="SignInTransform"
                                            X="0" />
                    </Grid.RenderTransform>
                    <StackPanel VerticalAlignment="Center"
                                HorizontalAlignment="Center">
                        <TextBlock Text="Đăng nhập"
                                   FontSize="26"
                                   FontWeight="Bold"
                                   Foreground="#222"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,25" />

                        <Border Style="{StaticResource InputContainer}">
                            <Grid>
                                <TextBlock Text="email@domain.com"
                                           Foreground="Gray"
                                           VerticalAlignment="Center"
                                           Margin="18,0,0,0"
                                           IsHitTestVisible="False" />
                                <TextBox Background="Transparent"
                                         BorderThickness="0"
                                         VerticalContentAlignment="Center"
                                         Padding="15,0"
                                         Foreground="#333"
                                         TextChanged="Placeholder_TextChanged" />
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource InputContainer}"
                                Margin="0,8,0,0">
                            <Grid>
                                <TextBlock Text="Mật khẩu"
                                           Foreground="Gray"
                                           VerticalAlignment="Center"
                                           Margin="18,0,0,0"
                                           IsHitTestVisible="False" />
                                <PasswordBox Background="Transparent"
                                             BorderThickness="0"
                                             VerticalContentAlignment="Center"
                                             Padding="15,0"
                                             Foreground="#333"
                                             PasswordChanged="Placeholder_PasswordChanged" />
                            </Grid>
                        </Border>

                        <Button Content="Quên mật khẩu?"
                                Style="{StaticResource LinkBtn}"
                                HorizontalAlignment="Right"
                                Margin="0,5,0,15"
                                Click="ForgotPassword_Click" />

                        <Button Content="ĐĂNG NHẬP"
                                Style="{StaticResource SolidBtn}"
                                Click="SignIn_Click" />

                        <TextBlock Text="Hoặc đăng nhập với"
                                   HorizontalAlignment="Center"
                                   Foreground="Gray"
                                   Margin="0,20,0,10"
                                   FontSize="12" />

                        <Button Background="White"
                                Width="300"
                                Height="42"
                                BorderThickness="1"
                                BorderBrush="#DCDCDC">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="8">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center" />
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="G"
                                           Foreground="#4285F4"
                                           FontWeight="Bold"
                                           Margin="0,0,10,0"
                                           VerticalAlignment="Center"
                                           FontSize="16" />
                                <TextBlock Text="Google"
                                           Foreground="Black"
                                           VerticalAlignment="Center"
                                           FontWeight="SemiBold" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>

                <Grid x:Name="SignUpPanel"
                      Width="400"
                      HorizontalAlignment="Left"
                      Panel.ZIndex="0"
                      Opacity="0"
                      IsHitTestVisible="False">
                    <Grid.RenderTransform>
                        <TranslateTransform x:Name="SignUpTransform"
                                            X="0" />
                    </Grid.RenderTransform>
                    <StackPanel VerticalAlignment="Center"
                                HorizontalAlignment="Center">
                        <TextBlock Text="Tạo tài khoản"
                                   FontSize="26"
                                   FontWeight="Bold"
                                   Foreground="#222"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,25" />
                        <Border Style="{StaticResource InputContainer}">
                            <Grid>
                                <TextBlock Text="Tên của bạn"
                                           Foreground="Gray"
                                           VerticalAlignment="Center"
                                           Margin="18,0,0,0"
                                           IsHitTestVisible="False" />
                                <TextBox Background="Transparent"
                                         BorderThickness="0"
                                         VerticalContentAlignment="Center"
                                         Padding="15,0"
                                         Foreground="#333"
                                         TextChanged="Placeholder_TextChanged" />
                            </Grid>
                        </Border>
                        <Border Style="{StaticResource InputContainer}">
                            <Grid>
                                <TextBlock Text="Email"
                                           Foreground="Gray"
                                           VerticalAlignment="Center"
                                           Margin="18,0,0,0"
                                           IsHitTestVisible="False" />
                                <TextBox Background="Transparent"
                                         BorderThickness="0"
                                         VerticalContentAlignment="Center"
                                         Padding="15,0"
                                         Foreground="#333"
                                         TextChanged="Placeholder_TextChanged" />
                            </Grid>
                        </Border>
                        <Border Style="{StaticResource InputContainer}">
                            <Grid>
                                <TextBlock Text="Mật khẩu"
                                           Foreground="Gray"
                                           VerticalAlignment="Center"
                                           Margin="18,0,0,0"
                                           IsHitTestVisible="False" />
                                <PasswordBox Background="Transparent"
                                             BorderThickness="0"
                                             VerticalContentAlignment="Center"
                                             Padding="15,0"
                                             Foreground="#333"
                                             PasswordChanged="Placeholder_PasswordChanged" />
                            </Grid>
                        </Border>
                        <Button Content="ĐĂNG KÝ"
                                Style="{StaticResource SolidBtn}"
                                Margin="0,10,0,0" />
                    </StackPanel>
                </Grid>

                <Border x:Name="OverlayPanel"
                        Width="250"
                        HorizontalAlignment="Left"
                        Panel.ZIndex="10"
                        Margin="10"
                        CornerRadius="25">
                    <Border.RenderTransform>
                        <TranslateTransform x:Name="OverlayTransform"
                                            X="400" />
                    </Border.RenderTransform>
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0"
                                             EndPoint="1,1">
                            <GradientStop x:Name="Stop1"
                                          Color="#FF0080"
                                          Offset="0.0" />
                            <GradientStop x:Name="Stop2"
                                          Color="#FF8C00"
                                          Offset="1.0" />
                        </LinearGradientBrush>
                    </Border.Background>

                    <Grid>
                        <StackPanel x:Name="OverlaySignUpContent"
                                    VerticalAlignment="Center"
                                    Margin="20">
                            <TextBlock Text="Chào bạn!"
                                       FontSize="26"
                                       FontWeight="Bold"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,12" />
                            <TextBlock Text="Bắt đầu hành trình mới cùng chúng tôi ngay hôm nay"
                                       Foreground="White"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,30"
                                       FontSize="13"
                                       LineHeight="18" />
                            <Button Content="ĐĂNG KÝ"
                                    Style="{StaticResource OutlineBtn}"
                                    Click="ShowSignUp_Click" />
                        </StackPanel>

                        <StackPanel x:Name="OverlaySignInContent"
                                    VerticalAlignment="Center"
                                    Margin="20"
                                    Opacity="0"
                                    IsHitTestVisible="False">
                            <TextBlock Text="Mừng trở lại!"
                                       FontSize="26"
                                       FontWeight="Bold"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,12" />
                            <TextBlock Text="Đăng nhập để tiếp tục quản lý dự án"
                                       Foreground="White"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,30"
                                       FontSize="13"
                                       LineHeight="18" />
                            <Button Content="ĐĂNG NHẬP"
                                    Style="{StaticResource OutlineBtn}"
                                    Click="ShowSignIn_Click" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <Button Style="{StaticResource CloseBtnStyle}"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,-10,-10,0"
                Click="CloseBtn_Click"
                Panel.ZIndex="100" />
    </Grid>
</Window>